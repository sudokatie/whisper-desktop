{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Whisper Desktop",
  "version": "0.1.0",
  "identifier": "com.blackabee.whisper-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Whisper",
        "width": 1000,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "notification": {},
    "autostart": {
      "macosExtraSetup": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "End-to-end encrypted messaging",
    "longDescription": "Whisper Desktop provides secure, end-to-end encrypted messaging that syncs with your mobile devices."
  }
}
